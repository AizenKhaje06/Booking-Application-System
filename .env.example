# =============================================================================
# RestaurantHub — Environment Variables
# Copy to .env for local dev. Set the same keys in Vercel → Project → Settings → Environment Variables.
# =============================================================================

# ─── App (required) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME="RestaurantHub"
# Production: https://your-domain.vercel.app or custom domain
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Database (required) ──────────────────────────────────────────────────────
# Local: PostgreSQL on localhost
# Production: Vercel Postgres, Neon, Supabase, or Railway connection string
# Use ?sslmode=require for managed Postgres in production
DATABASE_URL="postgresql://postgres:password@localhost:5432/restaurant_hub?schema=public"

# ─── NextAuth / Auth.js (required in production) ──────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Must match NEXT_PUBLIC_APP_URL in production
AUTH_URL="http://localhost:3000"
# Required on Vercel — Auth.js trusts the host header
AUTH_TRUST_HOST="true"

# ─── OAuth (optional) ─────────────────────────────────────────────────────────
# Google Cloud Console → OAuth 2.0 → Authorized redirect URI:
# https://your-domain.com/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ─── UploadThing (optional — venue gallery uploads) ───────────────────────────
UPLOADTHING_TOKEN=""
UPLOADTHING_APP_ID=""

# ─── Resend Email (optional — emails log to console if unset) ─────────────────
RESEND_API_KEY=""
RESEND_FROM_EMAIL="RestaurantHub <noreply@yourdomain.com>"

# ─── PayMongo (optional — GCash / Maya / card deposits) ───────────────────────
# Webhook URL: https://your-domain.com/api/paymongo/webhook
# Events: checkout_session.payment.paid, payment.failed
PAYMONGO_SECRET_KEY=""
PAYMONGO_PUBLIC_KEY=""
PAYMONGO_WEBHOOK_SECRET=""

# ─── Twilio SMS (optional) ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER="+15005550006"

# ─── Cron (required in production) ────────────────────────────────────────────
# Vercel Cron sends: Authorization: Bearer <CRON_SECRET>
# Generate: openssl rand -base64 32
CRON_SECRET=""

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV="development"
